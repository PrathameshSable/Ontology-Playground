        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/loan_rate_type">
        <rdfs:label>rate_type</rdfs:label>
