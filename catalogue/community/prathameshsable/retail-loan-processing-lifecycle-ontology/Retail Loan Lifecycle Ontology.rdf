        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Outstanding balance in Indian Rupees.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/loan_loan_status">
        <rdfs:label>loan_status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Active / Closed / Foreclosed / Written-Off / Restructured.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/loan_ind_as_109_stage">
        <rdfs:label>ind_as_109_stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>ECL stage: 1 (performing), 2 (significant credit deterioration), 3 (credit-impaired).</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/repayment_Schedule_schedule_id">
