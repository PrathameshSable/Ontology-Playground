        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Schedule entry identifier. [Entity key for Repayment_Schedule]</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/repayment_Schedule_instalment_no">
        <rdfs:label>instalment_no</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Repayment_Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Instalment sequence number.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/repayment_Schedule_due_date">
        <rdfs:label>due_date</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Repayment_Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Due date of the instalment.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/repayment_Schedule_schedule_status">
        <rdfs:label>schedule_status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Repayment_Schedule"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Scheduled / Paid / Overdue / Partial.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/payment_payment_id">
        <rdfs:label>payment_id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Payment identifier. [Entity key for Payment]</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/payment_payment_date">
        <rdfs:label>payment_date</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Payment date.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/payment_payment_amount_inr">
        <rdfs:label>payment_amount_inr</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Payment amount in Indian Rupees.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/payment_payment_mode">
        <rdfs:label>payment_mode</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>NACH / UPI AutoPay / Cheque / Cash / IMPS / NEFT / RTGS.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/payment_payment_status">
        <rdfs:label>payment_status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Successful / Bounced / Reversed / Pending.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/nPA_Classification_npa_classification_id">
        <rdfs:label>npa_classification_id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/NPA_Classification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>NPA classification identifier. [Entity key for NPA_Classification]</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/nPA_Classification_days_past_due">
        <rdfs:label>days_past_due</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/NPA_Classification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Days past due.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/nPA_Classification_asset_class">
        <rdfs:label>asset_class</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/NPA_Classification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>RBI IRACP classification: Standard, SMA-0, SMA-1, SMA-2, Sub-Standard, Doubtful, Loss.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/nPA_Classification_provision_inr">
        <rdfs:label>provision_inr</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/NPA_Classification"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Provisioning amount under Ind AS 109 ECL.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/regulatory_Report_reg_report_id">
        <rdfs:label>reg_report_id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Regulatory_Report"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Regulatory report identifier. [Entity key for Regulatory_Report]</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/regulatory_Report_reg_report_type">
        <rdfs:label>reg_report_type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Regulatory_Report"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>CRILC / DSB-I / DSB-II / DSB-III / NPA Return / Priority Sector Return / CIC Monthly.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/regulatory_Report_submitted_to_regulator">
        <rdfs:label>submitted_to_regulator</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Regulatory_Report"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>RBI / SEBI / NABARD / CIBIL / Experian / Equifax / CRIF Highmark.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/employed_by">
        <rdfs:label>employed_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Employer"/>
        <rdfs:comment>Salaried customer to employer - used for income verification under RBI Fair Practices Code and for employer concentration risk analysis.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>employer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/belongs_to_lender">
        <rdfs:label>belongs_to_lender</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Branch"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Lender"/>
        <rdfs:comment>Branch belongs to a Bank or NBFC.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>branch</ont:fromEntityId>
        <ont:toEntityId>lender</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/employs">
        <rdfs:label>employs</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Branch"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Employee"/>
        <rdfs:comment>Branch employs staff (relationship managers, credit officers, underwriters, collections agents).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>branch</ont:fromEntityId>
        <ont:toEntityId>employee</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/submitted_by">
        <rdfs:label>submitted_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Customer"/>
        <rdfs:comment>Application is submitted by the primary customer (the borrower).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_co_applicant">
        <rdfs:label>has_co_applicant</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Customer"/>
        <rdfs:comment>Application optionally has a co-applicant (jointly liable, typically spouse on Home Loan or parent on Education Loan).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_guarantor">
        <rdfs:label>has_guarantor</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Customer"/>
        <rdfs:comment>Application optionally has a guarantor providing a personal guarantee under Section 126 of the Indian Contract Act.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/originated_at">
        <rdfs:label>originated_at</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Branch"/>
        <rdfs:comment>Application originated at a specific branch or digital origination point.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>branch</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/for_product">
        <rdfs:label>for_product</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Product"/>
        <rdfs:comment>Application is for a specific retail loan product.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/sourced_via">
        <rdfs:label>sourced_via</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/DSA"/>
        <rdfs:comment>Application was optionally sourced via a Direct Selling Agent under RBI outsourcing norms.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>dSA</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_kyc">
        <rdfs:label>has_kyc</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/KYC_Record"/>
        <rdfs:comment>Application has a KYC verification record per the RBI KYC Master Direction.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>kYC_Record</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_assessment">
        <rdfs:label>has_assessment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Credit_Assessment"/>
        <rdfs:comment>Application is underwritten via a credit assessment capturing FOIR, internal grade and Ind AS 109 risk parameters.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>credit_Assessment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/fraud_checked">
        <rdfs:label>fraud_checked</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Fraud_Check"/>
        <rdfs:comment>Application is screened through internal and external fraud checks.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>fraud_Check</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/evidenced_by">
        <rdfs:label>evidenced_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Application"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Document"/>
        <rdfs:comment>Application is supported by multiple documents (PAN, Aadhaar, payslip, bank statement, etc.). One application maps to many documents.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>application</ont:fromEntityId>
        <ont:toEntityId>document</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/uses_bureau_report">
        <rdfs:label>uses_bureau_report</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Credit_Assessment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Credit_Bureau_Report"/>
        <rdfs:comment>Credit assessment uses a credit bureau report from one of the four CICs (CIBIL TransUnion, Experian, Equifax, CRIF Highmark).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>credit_Assessment</ont:fromEntityId>
        <ont:toEntityId>credit_Bureau_Report</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_decision">
        <rdfs:label>has_decision</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Credit_Assessment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Decision"/>
        <rdfs:comment>Credit assessment produces a decision: Approved, Declined, Referred or Conditional Approval.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>credit_Assessment</ont:fromEntityId>
        <ont:toEntityId>decision</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/decided_by">
        <rdfs:label>decided_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Decision"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Employee"/>
        <rdfs:comment>Decision was made by a specific employee (credit officer, underwriter or branch manager). Accountability trail per RBI Fair Practices Code.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>decision</ont:fromEntityId>
        <ont:toEntityId>employee</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/triggers_sanction">
        <rdfs:label>triggers_sanction</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Decision"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Sanction_Letter"/>
        <rdfs:comment>An approved decision triggers the issuance of a Sanction Letter to the customer per RBI Key Fact Statement norms.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>decision</ont:fromEntityId>
        <ont:toEntityId>sanction_Letter</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/books_loan">
        <rdfs:label>books_loan</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Sanction_Letter"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:comment>Sanction letter, when accepted and disbursed, books a Loan account.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>sanction_Letter</ont:fromEntityId>
        <ont:toEntityId>loan</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/held_by">
        <rdfs:label>held_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Customer"/>
        <rdfs:comment>Loan is held by the primary borrower (customer).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/booked_by_lender">
        <rdfs:label>booked_by_lender</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Lender"/>
        <rdfs:comment>Loan is booked on the books of a specific lender (Bank or NBFC).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>lender</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/secured_by">
        <rdfs:label>secured_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Collateral"/>
        <rdfs:comment>Loan is optionally secured by collateral (Property, Vehicle, or Gold). Null for unsecured products.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>collateral</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_schedule">
        <rdfs:label>has_schedule</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Repayment_Schedule"/>
        <rdfs:comment>Loan has a repayment schedule - one row per scheduled EMI instalment over the loan tenure.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>repayment_Schedule</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_payment">
        <rdfs:label>has_payment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:comment>Loan has received zero or more EMI payments via NACH, UPI AutoPay, NEFT, IMPS, RTGS, cheque or cash.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>payment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/pays_instalment">
        <rdfs:label>pays_instalment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Payment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Repayment_Schedule"/>
        <rdfs:comment>A Payment settles a specific scheduled instalment - the link between the schedule plan and the actual inflow.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>payment</ont:fromEntityId>
        <ont:toEntityId>repayment_Schedule</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/has_npa_status">
        <rdfs:label>has_npa_status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/NPA_Classification"/>
        <rdfs:comment>Loan has NPA classification(s) over time under RBI IRACP norms. Drives provisioning under Ind AS 109.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>nPA_Classification</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/india-retail-loan-processing-ontology/aggregated_into">
        <rdfs:label>aggregated_into</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Loan"/>
        <rdfs:range rdf:resource="http://example.org/ontology/india-retail-loan-processing-ontology/Regulatory_Report"/>
        <rdfs:comment>Loan is reported into regulatory submissions: CRILC (large exposures), DSB returns, NPA returns, Priority Sector Lending and monthly CIC submissions.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>loan</ont:fromEntityId>
        <ont:toEntityId>regulatory_Report</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
